<script>
  // Init
  const today = new Date();
  document.getElementById('visitDate').value = today.toISOString().split('T')[0];
  document.getElementById('currentDate').textContent = today.toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' });

  // Generate report ID
  const reportNum = Math.floor(Math.random() * 9000) + 1000;
  document.getElementById('reportId').textContent = `SVR-${reportNum}`;

  // Issues
  function addIssue() {
    const list = document.getElementById('issueList');
    const count = list.children.length + 1;
    const div = document.createElement('div');
    div.className = 'issue-item';
    div.innerHTML = `<input type="text" placeholder="Describe issue #${count}"><button class="remove-btn" onclick="removeIssue(this)">×</button>`;
    list.appendChild(div);
  }

  function removeIssue(btn) {
    const list = document.getElementById('issueList');
    if (list.children.length > 1) btn.parentElement.remove();
  }

  // Materials toggle
  function toggleMaterials() {
    const checked = document.getElementById('materialsNeeded').checked;
    document.getElementById('materialsSection').style.display = checked ? 'block' : 'none';
    if (!checked) {
      document.getElementById('bypassBanner').classList.remove('visible');
      document.querySelectorAll('.urgency-btn').forEach(b => b.className = 'urgency-btn');
    }
  }

  // Urgency
  let currentUrgency = '';
  function setUrgency(level, btn) {
    document.querySelectorAll('.urgency-btn').forEach(b => b.className = 'urgency-btn');
    btn.classList.add(`active-${level}`);
    currentUrgency = level;
    const banner = document.getElementById('bypassBanner');
    banner.classList.toggle('visible', level === 'high');
  }

  // Preview
  function previewReport() {
    const issues = [...document.querySelectorAll('#issueList .issue-item input')].map(i => i.value).filter(Boolean);
    const urgencyLabels = { low: 'LOW — Thursday List', medium: 'MEDIUM — This Week', high: 'HIGH — BYPASS PROCESS' };
    const urgencyTagClass = { low: 'tag-green', medium: 'tag-yellow', high: 'tag-red' };

    const formatField = (label, value) => value ? `
      <div class="preview-block">
        <div class="preview-label">${label}</div>
        <div class="preview-value">${value}</div>
      </div>` : '';

    let html = '';
    html += formatField('Client', document.getElementById('client').value);
    html += formatField('Job Site', document.getElementById('jobSite').value);

    const visitDate = document.getElementById('visitDate').value;
    const arrival = document.getElementById('arrivalTime').value;
    const departure = document.getElementById('departureTime').value;
    const timeStr = [visitDate, arrival && departure ? `${arrival} – ${departure}` : arrival || departure].filter(Boolean).join(' | ');
    html += formatField('Date & Time', timeStr);

    html += formatField('Foreman', document.getElementById('foreman').value);
    html += formatField('GC Representative', document.getElementById('gcRep').value);

    if (issues.length) {
      html += `<div class="preview-block"><div class="preview-label">Issues Found</div><div class="preview-value">${issues.map((i,n) => `${n+1}. ${i}`).join('<br>')}</div></div>`;
    }

    if (document.getElementById('materialsNeeded').checked) {
      const mats = document.getElementById('materialsList').value;
      if (mats) {
        let urgencyTag = currentUrgency ? `<span class="preview-tag ${urgencyTagClass[currentUrgency]}">${urgencyLabels[currentUrgency]}</span>` : '';
        html += `<div class="preview-block"><div class="preview-label">Materials Needed</div><div class="preview-value">${mats}<br><br>${urgencyTag}</div></div>`;
      }
      const supplier = document.getElementById('supplier').value;
      html += formatField('Supplier', supplier);
      const marioNotified = document.getElementById('marioNotified').value;
      html += formatField('Mario Notified (Materials)', marioNotified);
    }

    html += formatField('GC Blocking Us', document.getElementById('gcBlocking').value);
    html += formatField('We Blocking GC', document.getElementById('weBlocking').value);
    html += formatField('GC Blockage Details', document.getElementById('gcBlockageDetail').value);
    html += formatField('Our Delay to GC', document.getElementById('ourDelayDetail').value);
    html += formatField('Actions Taken', document.getElementById('actionsTaken').value);
    html += formatField('Follow-Up Required', document.getElementById('followUp').value);
    html += formatField('Notify Mario', document.getElementById('notifyMario').value);

    const nextVisit = document.getElementById('nextVisit').value;
    html += formatField('Next Site Visit', nextVisit);
    html += formatField('Additional Notes', document.getElementById('additionalNotes').value);

    document.getElementById('modalContent').innerHTML = html || '<p style="color:var(--text-muted)">No data entered yet.</p>';
    document.getElementById('modalOverlay').classList.add('open');
  }

  function closeModal() {
    document.getElementById('modalOverlay').classList.remove('open');
  }

  function copyReport() {
    const client = document.getElementById('client').value || '—';
    const jobSite = document.getElementById('jobSite').value || '—';
    const visitDate = document.getElementById('visitDate').value || '—';
    const foreman = document.getElementById('foreman').value || '—';
    const gcRep = document.getElementById('gcRep').value || '—';
    const issues = [...document.querySelectorAll('#issueList .issue-item input')].map((i,n) => `  ${n+1}. ${i.value}`).filter(v => v.trim() !== `  ${issues ? issues.indexOf(v)+1 : 1}. `).join('\n');
    const issuesClean = [...document.querySelectorAll('#issueList .issue-item input')].map((i,n) => `  ${n+1}. ${i.value}`).filter(i => i.trim().length > 4).join('\n');

    let text = `SITE VISIT REPORT — Aesthetic E Consulting\n`;
    text += `Report ID: ${document.getElementById('reportId').textContent}\n`;
    text += `Date: ${visitDate}\n\n`;
    text += `CLIENT: ${client}\nJOB SITE: ${jobSite}\nFOREMAN: ${foreman}\nGC REP: ${gcRep}\n\n`;
    if (issuesClean) text += `ISSUES FOUND:\n${issuesClean}\n\n`;
    if (document.getElementById('materialsNeeded').checked) {
      text += `MATERIALS NEEDED:\n${document.getElementById('materialsList').value}\nUrgency: ${currentUrgency.toUpperCase() || '—'}\n\n`;
    }
    text += `GC BLOCKING US: ${document.getElementById('gcBlocking').value || '—'}\n`;
    text += `WE BLOCKING GC: ${document.getElementById('weBlocking').value || '—'}\n`;
    if (document.getElementById('gcBlockageDetail').value) text += `\nGC BLOCKAGE DETAILS:\n${document.getElementById('gcBlockageDetail').value}\n`;
    if (document.getElementById('ourDelayDetail').value) text += `\nOUR DELAY TO GC:\n${document.getElementById('ourDelayDetail').value}\n`;
    if (document.getElementById('actionsTaken').value) text += `\nACTIONS TAKEN:\n${document.getElementById('actionsTaken').value}\n`;
    if (document.getElementById('followUp').value) text += `\nFOLLOW-UP REQUIRED:\n${document.getElementById('followUp').value}\n`;
    text += `\nNOTIFY MARIO: ${document.getElementById('notifyMario').value || '—'}\n`;
    if (document.getElementById('additionalNotes').value) text += `\nADDITIONAL NOTES:\n${document.getElementById('additionalNotes').value}\n`;

    navigator.clipboard.writeText(text).then(() => {
      const btn = document.querySelector('.modal .btn-primary');
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy Report Text', 2000);
    });
  }

  function clearForm() {
    if (confirm('Clear all fields?')) {
      document.querySelectorAll('input[type="text"], textarea').forEach(el => el.value = '');
      document.querySelectorAll('select').forEach(el => el.selectedIndex = 0);
      document.getElementById('client').value = 'Ampacity Electric';
      document.getElementById('visitDate').value = new Date().toISOString().split('T')[0];
      document.getElementById('materialsNeeded').checked = false;
      document.getElementById('materialsSection').style.display = 'none';
      document.getElementById('bypassBanner').classList.remove('visible');
      document.querySelectorAll('.urgency-btn').forEach(b => b.className = 'urgency-btn');
      currentUrgency = '';
      const list = document.getElementById('issueList');
      while (list.children.length > 1) list.lastChild.remove();
      list.firstChild.querySelector('input').value = '';
    }
  }
</script>

</body>
</html>
