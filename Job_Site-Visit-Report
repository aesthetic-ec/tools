<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Site Visit Report — Aesthetic E Consulting</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #0a0a0a;
    --white: #f5f3ee;
    --accent: #c8a96e;
    --accent-dim: #8a6f3f;
    --surface: #141414;
    --surface2: #1e1e1e;
    --border: #2a2a2a;
    --text-muted: #666;
    --red: #c0392b;
    --green: #27ae60;
    --yellow: #e67e22;
  }

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
background: var(–black);
color: var(–white);
font-family: ‘DM Sans’, sans-serif;
min-height: 100vh;
padding: 40px 20px 80px;
}

.page {
max-width: 820px;
margin: 0 auto;
}

/* Header */
.header {
border-bottom: 1px solid var(–accent);
padding-bottom: 24px;
margin-bottom: 40px;
display: flex;
justify-content: space-between;
align-items: flex-end;
flex-wrap: wrap;
gap: 16px;
}

.brand {
font-family: ‘Syne’, sans-serif;
font-size: 11px;
font-weight: 700;
letter-spacing: 0.2em;
text-transform: uppercase;
color: var(–accent);
}

.doc-title {
font-family: ‘Syne’, sans-serif;
font-size: 28px;
font-weight: 800;
line-height: 1;
margin-top: 6px;
}

.doc-meta {
text-align: right;
font-family: ‘DM Mono’, monospace;
font-size: 11px;
color: var(–text-muted);
line-height: 1.8;
}

.report-id {
font-family: ‘DM Mono’, monospace;
font-size: 13px;
color: var(–accent);
font-weight: 500;
}

/* Sections */
.section {
margin-bottom: 32px;
background: var(–surface);
border: 1px solid var(–border);
border-radius: 4px;
overflow: hidden;
animation: fadeUp 0.4s ease both;
}

@keyframes fadeUp {
from { opacity: 0; transform: translateY(12px); }
to { opacity: 1; transform: translateY(0); }
}

.section:nth-child(1) { animation-delay: 0.05s; }
.section:nth-child(2) { animation-delay: 0.1s; }
.section:nth-child(3) { animation-delay: 0.15s; }
.section:nth-child(4) { animation-delay: 0.2s; }
.section:nth-child(5) { animation-delay: 0.25s; }
.section:nth-child(6) { animation-delay: 0.3s; }

.section-header {
background: var(–surface2);
padding: 14px 20px;
border-bottom: 1px solid var(–border);
display: flex;
align-items: center;
gap: 12px;
}

.section-number {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–accent);
letter-spacing: 0.1em;
}

.section-title {
font-family: ‘Syne’, sans-serif;
font-size: 13px;
font-weight: 700;
letter-spacing: 0.08em;
text-transform: uppercase;
}

.section-body {
padding: 20px;
}

/* Form fields */
.field-row {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 16px;
margin-bottom: 16px;
}

.field-row.single { grid-template-columns: 1fr; }
.field-row.triple { grid-template-columns: 1fr 1fr 1fr; }

.field {
display: flex;
flex-direction: column;
gap: 6px;
}

label {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
letter-spacing: 0.12em;
text-transform: uppercase;
color: var(–text-muted);
}

input[type=“text”],
input[type=“date”],
input[type=“time”],
select,
textarea {
background: var(–black);
border: 1px solid var(–border);
border-radius: 3px;
color: var(–white);
font-family: ‘DM Sans’, sans-serif;
font-size: 14px;
padding: 10px 12px;
transition: border-color 0.2s;
outline: none;
width: 100%;
}

input:focus, select:focus, textarea:focus {
border-color: var(–accent);
}

textarea {
resize: vertical;
min-height: 80px;
line-height: 1.6;
}

select option { background: var(–surface); }

/* Urgency selector */
.urgency-group {
display: flex;
gap: 8px;
flex-wrap: wrap;
}

.urgency-btn {
flex: 1;
min-width: 90px;
padding: 10px 12px;
border: 1px solid var(–border);
border-radius: 3px;
background: var(–black);
color: var(–text-muted);
font-family: ‘DM Mono’, monospace;
font-size: 11px;
letter-spacing: 0.08em;
cursor: pointer;
text-align: center;
transition: all 0.2s;
}

.urgency-btn:hover { border-color: var(–accent); color: var(–white); }
.urgency-btn.active-low { border-color: var(–green); color: var(–green); background: rgba(39,174,96,0.08); }
.urgency-btn.active-medium { border-color: var(–yellow); color: var(–yellow); background: rgba(230,126,34,0.08); }
.urgency-btn.active-high { border-color: var(–red); color: var(–red); background: rgba(192,57,43,0.08); }

/* Toggle */
.toggle-row {
display: flex;
align-items: center;
justify-content: space-between;
padding: 12px 0;
border-bottom: 1px solid var(–border);
}
.toggle-row:last-child { border-bottom: none; }

.toggle-label {
font-size: 14px;
color: var(–white);
}

.toggle-sub {
font-size: 12px;
color: var(–text-muted);
margin-top: 2px;
}

.toggle {
position: relative;
width: 44px;
height: 24px;
flex-shrink: 0;
}

.toggle input { opacity: 0; width: 0; height: 0; }

.toggle-slider {
position: absolute;
inset: 0;
background: var(–border);
border-radius: 12px;
cursor: pointer;
transition: 0.3s;
}

.toggle-slider:before {
content: ‘’;
position: absolute;
width: 18px;
height: 18px;
left: 3px;
top: 3px;
background: var(–text-muted);
border-radius: 50%;
transition: 0.3s;
}

.toggle input:checked + .toggle-slider { background: rgba(200,169,110,0.25); }
.toggle input:checked + .toggle-slider:before {
transform: translateX(20px);
background: var(–accent);
}

/* Material bypass */
.bypass-banner {
background: rgba(192,57,43,0.1);
border: 1px solid rgba(192,57,43,0.4);
border-radius: 3px;
padding: 12px 16px;
margin-bottom: 16px;
font-family: ‘DM Mono’, monospace;
font-size: 11px;
color: #e07060;
letter-spacing: 0.05em;
display: none;
}

.bypass-banner.visible { display: block; }

/* Issues list */
.issue-list { display: flex; flex-direction: column; gap: 10px; }

.issue-item {
display: flex;
gap: 10px;
align-items: flex-start;
}

.issue-item input[type=“text”] { flex: 1; }

.remove-btn {
background: none;
border: 1px solid var(–border);
color: var(–text-muted);
width: 38px;
height: 38px;
border-radius: 3px;
cursor: pointer;
font-size: 16px;
flex-shrink: 0;
transition: all 0.2s;
display: flex;
align-items: center;
justify-content: center;
}

.remove-btn:hover { border-color: var(–red); color: var(–red); }

.add-btn {
margin-top: 10px;
background: none;
border: 1px dashed var(–border);
color: var(–text-muted);
padding: 9px 16px;
border-radius: 3px;
cursor: pointer;
font-family: ‘DM Mono’, monospace;
font-size: 11px;
letter-spacing: 0.08em;
transition: all 0.2s;
width: 100%;
}

.add-btn:hover { border-color: var(–accent); color: var(–accent); }

/* Status indicators */
.status-grid {
display: grid;
grid-template-columns: 1fr 1fr;
gap: 10px;
}

.status-card {
border: 1px solid var(–border);
border-radius: 3px;
padding: 14px;
background: var(–black);
}

.status-card-label {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–text-muted);
letter-spacing: 0.1em;
text-transform: uppercase;
margin-bottom: 8px;
}

/* Actions bar */
.actions {
display: flex;
gap: 12px;
margin-top: 40px;
flex-wrap: wrap;
}

.btn-primary {
background: var(–accent);
color: var(–black);
border: none;
padding: 14px 28px;
border-radius: 3px;
font-family: ‘Syne’, sans-serif;
font-weight: 700;
font-size: 13px;
letter-spacing: 0.08em;
text-transform: uppercase;
cursor: pointer;
transition: all 0.2s;
}

.btn-primary:hover { background: #d4b87a; transform: translateY(-1px); }

.btn-secondary {
background: none;
color: var(–white);
border: 1px solid var(–border);
padding: 14px 28px;
border-radius: 3px;
font-family: ‘Syne’, sans-serif;
font-weight: 600;
font-size: 13px;
letter-spacing: 0.08em;
text-transform: uppercase;
cursor: pointer;
transition: all 0.2s;
}

.btn-secondary:hover { border-color: var(–accent); color: var(–accent); }

/* Preview modal */
.modal-overlay {
position: fixed;
inset: 0;
background: rgba(0,0,0,0.85);
z-index: 100;
display: none;
align-items: flex-start;
justify-content: center;
padding: 40px 20px;
overflow-y: auto;
}

.modal-overlay.open { display: flex; }

.modal {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 4px;
max-width: 700px;
width: 100%;
padding: 32px;
font-family: ‘DM Sans’, sans-serif;
}

.modal-header {
display: flex;
justify-content: space-between;
align-items: center;
margin-bottom: 24px;
padding-bottom: 16px;
border-bottom: 1px solid var(–accent);
}

.modal-title {
font-family: ‘Syne’, sans-serif;
font-size: 18px;
font-weight: 800;
}

.close-btn {
background: none;
border: none;
color: var(–text-muted);
font-size: 20px;
cursor: pointer;
padding: 4px;
}

.preview-block {
margin-bottom: 20px;
padding-bottom: 20px;
border-bottom: 1px solid var(–border);
}

.preview-block:last-child { border-bottom: none; margin-bottom: 0; }

.preview-label {
font-family: ‘DM Mono’, monospace;
font-size: 10px;
color: var(–accent);
letter-spacing: 0.12em;
text-transform: uppercase;
margin-bottom: 8px;
}

.preview-value {
font-size: 14px;
line-height: 1.6;
color: var(–white);
}

.preview-tag {
display: inline-block;
padding: 3px 10px;
border-radius: 2px;
font-family: ‘DM Mono’, monospace;
font-size: 11px;
margin: 2px;
}

.tag-red { background: rgba(192,57,43,0.2); color: #e07060; border: 1px solid rgba(192,57,43,0.3); }
.tag-yellow { background: rgba(230,126,34,0.2); color: #e8a060; border: 1px solid rgba(230,126,34,0.3); }
.tag-green { background: rgba(39,174,96,0.2); color: #60c880; border: 1px solid rgba(39,174,96,0.3); }

@media (max-width: 600px) {
.field-row { grid-template-columns: 1fr; }
.field-row.triple { grid-template-columns: 1fr; }
.status-grid { grid-template-columns: 1fr; }
.header { flex-direction: column; align-items: flex-start; }
.doc-meta { text-align: left; }
}

.divider {
height: 1px;
background: var(–border);
margin: 16px 0;
}
</style>

</head>
